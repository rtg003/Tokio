# ============================================================================
# Tokio — template de variáveis de ambiente
# Copie para `.env` (permissão 600) e preencha FORA de qualquer sessão de
# agente. NUNCA commite o `.env` real. Valores jamais devem ser logados.
# ============================================================================

# --- Rede / corretora -------------------------------------------------------
# Rede ativa: testnet | mainnet (mainnet exige gate humano — ver HANDOFF)
HL_NETWORK=testnet
# Endereço da conta master (usado para queries; agent wallets só assinam)
HL_ACCOUNT_ADDRESS=
# Chave privada da agent wallet `engine_gateway` (único signatário do engine)
HL_AGENT_PRIVATE_KEY=

# --- Supabase (projeto novo, separado do Luthor) ----------------------------
SUPABASE_URL=
SUPABASE_ANON_KEY=
# service_role: SOMENTE nos containers do engine (replicador). Nunca no web.
SUPABASE_SERVICE_ROLE_KEY=
# Postgres direto (migrations no Supabase)
DATABASE_URL=

# --- Gateway / IPC interno --------------------------------------------------
# Token compartilhado entre runners/web e a API de controle do gateway
GATEWAY_CONTROL_TOKEN=
GATEWAY_HOST=gateway
GATEWAY_PORT=8700

# --- TradingView webhook -----------------------------------------------------
# Token secreto exigido em todo alerta recebido
TV_WEBHOOK_TOKEN=
TV_WEBHOOK_PORT=8701

# --- Notificações ------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Web (Next.js) ----------------------------------------------------------
# O web usa apenas URL + anon key (RLS ligado); nunca a service_role
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
