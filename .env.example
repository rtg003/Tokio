# ============================================================================
# Tokio — template de variáveis de ambiente
# Copie para `.env` (permissão 600) e preencha FORA de qualquer sessão de
# agente. NUNCA commite o `.env` real. Valores jamais devem ser logados.
# ============================================================================

# --- Rede / corretora -------------------------------------------------------
# Rede ativa: testnet | mainnet (mainnet exige gate humano — ver HANDOFF)
HL_NETWORK=testnet
# Endereço da conta master (usado para queries; agent wallets só assinam)
HL_ACCOUNT_ADDRESS=
# Chave privada da agent wallet `engine_gateway` (único signatário do engine)
HL_AGENT_PRIVATE_KEY=

# --- Gateway / IPC interno --------------------------------------------------
# Token compartilhado entre runners/web e a API de controle do gateway
GATEWAY_CONTROL_TOKEN=
# docker compose (dev): gateway · VPS compartilhada (systemd): 127.0.0.1
GATEWAY_HOST=gateway
GATEWAY_PORT=8700

# --- TradingView webhook -----------------------------------------------------
# Token secreto exigido em todo alerta recebido
TV_WEBHOOK_TOKEN=
TV_WEBHOOK_PORT=8701

# --- Notificações ------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Web (Next.js) ----------------------------------------------------------
# Auth simples do dashboard. Use valores fortes e mantenha o .env com chmod 600.
DASHBOARD_PASSWORD=
DASHBOARD_AUTH_SECRET=
# Opcional: deixe ausente em produção (true por padrão com NODE_ENV=production).
# Use "false" apenas em validações locais via HTTP.
DASHBOARD_COOKIE_SECURE=

# --- Backup SQLite ----------------------------------------------------------
# Opcional: destino offsite para deploy/backup_sqlite.sh (rclone remote:path,
# scp://user@host/path ou file:///path para teste local).
BACKUP_REMOTE=
