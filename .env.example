# ============================================================================
# Tokio — template de variáveis de ambiente
# Copie para `.env` (permissão 600) e preencha FORA de qualquer sessão de
# agente. NUNCA commite o `.env` real. Valores jamais devem ser logados.
# ============================================================================

# --- Rede / corretora -------------------------------------------------------
# Rede ativa: testnet | mainnet (mainnet exige gate humano — ver HANDOFF)
HL_NETWORK=testnet
# Endereço da conta master (usado para queries; agent wallets só assinam)
HL_ACCOUNT_ADDRESS=
# Chave privada da agent wallet `engine_gateway` (único signatário do engine)
HL_AGENT_PRIVATE_KEY=
# Credenciais MAINNET (coletadas pelo Hermes com o humano; sem elas a opção
# MAINNET do dashboard é recusada pelo gateway).
HL_MAINNET_ACCOUNT_ADDRESS=
HL_MAINNET_AGENT_PRIVATE_KEY=
# Segredo do keyring cifrado (AES-256-GCM) das agent wallets provisionadas pela
# UI (SPEC hl-auth v2.0). Alta entropia; posto no systemd/.env e NUNCA no backup
# offsite (DISCOVERY V7). Com ele configurado, o gateway resolve a agent key de
# cada ambiente na ordem keyring (hl_agents active) → fallback nas vars acima.
# Perdê-lo torna as chaves cifradas ilegíveis — guarde-o com o mesmo cuidado das
# chaves. Gere com: python -c "import secrets; print(secrets.token_urlsafe(48))"
TOKIO_KEYRING_SECRET=

# --- Gateway / IPC interno --------------------------------------------------
# Token compartilhado entre runners/web e a API de controle do gateway
GATEWAY_CONTROL_TOKEN=
# docker compose (dev): gateway · VPS compartilhada (systemd): 127.0.0.1
GATEWAY_HOST=gateway
GATEWAY_PORT=8700

# --- TradingView webhook -----------------------------------------------------
# Token secreto exigido em todo alerta recebido
TV_WEBHOOK_TOKEN=
TV_WEBHOOK_PORT=8701

# --- Notificações ------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Web (Next.js) ----------------------------------------------------------
# Auth simples do dashboard. Use valores fortes e mantenha o .env com chmod 600.
DASHBOARD_PASSWORD=
DASHBOARD_AUTH_SECRET=
# Opcional: deixe ausente em produção (true por padrão com NODE_ENV=production).
# Use "false" apenas em validações locais via HTTP.
DASHBOARD_COOKIE_SECURE=
# Login por carteira (SIWE/EIP-4361). Lista de endereços autorizados a logar via
# MetaMask, separados por vírgula (case-insensitive). VAZIO = SIWE desligado
# (só senha). Emite o mesmo cookie tokio_session da senha; NÃO afeta o caminho
# de ordem do gateway (/intent, /cancel) — é só login humano na dashboard.
AUTH_ALLOWED_ADDRESSES=

# --- Backup SQLite ----------------------------------------------------------
# Opcional: destino offsite para deploy/backup_sqlite.sh (rclone remote:path,
# scp://user@host/path ou file:///path para teste local).
BACKUP_REMOTE=
